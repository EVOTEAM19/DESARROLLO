# ============================================
# CONFIGURACIÓN SUPABASE
# ============================================
# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Anon key de Supabase (pública, segura para usar en cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SOLO para operaciones server-side, NUNCA exponer en cliente)
# Opcional: Solo necesario para operaciones administrativas avanzadas
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# CONFIGURACIÓN DEL SITIO
# ============================================
# URL completa del sitio (sin trailing slash)
# Desarrollo: http://localhost:3001
# Producción: https://www.fastia.es
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ============================================
# ANALYTICS Y TRACKING (OPCIONAL)
# ============================================
# Google Analytics 4 Measurement ID
# Formato: G-XXXXXXXXXX
# Obtener en: https://analytics.google.com
# Tu Measurement ID: G-7PKNBN52F3
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-7PKNBN52F3

# Google Analytics 4 Property ID (para Admin Dashboard)
# Formato: solo números (ej: 123456789)
# Obtener en: Google Analytics > Admin > Property Settings
# Tu Property ID: 520060270
GA4_PROPERTY_ID=520060270

# Google Analytics 4 Service Account Key (JSON como string)
# Obtener creando Service Account en Google Cloud Console
# Instrucciones en: GA4_SETUP.md
# Formato: JSON completo como string o ruta al archivo .json (desarrollo local)
# Opción 1: Para desarrollo local (usar esta):
GA4_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json
# Opción 2: Para producción en Vercel (JSON completo como string en una línea):
# GA4_SERVICE_ACCOUNT_KEY=

# Meta Pixel (Facebook/Instagram)
# Formato: números (ej: 123456789012345)
# Obtener en: https://business.facebook.com/events_manager2
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag
# Formato: números (ej: 123456)
# Obtener en: https://www.linkedin.com/campaignmanager/
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Microsoft Clarity
# Formato: letras/números (ej: abc123def456)
# Obtener en: https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ============================================
# EMAIL (RESEND)
# ============================================
# API Key de Resend para envío de correos
# Obtener en: https://resend.com/api-keys
# Formato: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nota: Debes verificar el dominio fastia.es en Resend antes de usar
RESEND_API_KEY=

# Email remitente (opcional)
# Si fastia.es está verificado en Resend, usa: FastIA <noreply@fastia.es>
# Si no está verificado, usa temporalmente: FastIA <onboarding@resend.dev>
RESEND_FROM_EMAIL=FastIA <onboarding@resend.dev>

# ============================================
# ENTORNO
# ============================================
# development | production
NODE_ENV=development
